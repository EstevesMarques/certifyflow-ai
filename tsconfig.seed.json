{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".seed-build",
    "rootDir": "."
  },
  "include": ["scripts/**/*", "*.json"],
  "exclude": ["node_modules", ".next", "app", "components", "lib", "public"]
}
